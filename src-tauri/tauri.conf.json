{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "音浪壁纸",
  "mainBinaryName": "YinlangWallpaper",
  "version": "0.2.0",
  "identifier": "com.lucky.yinlang-wallpaper",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "音浪壁纸",
        "width": 1280,
        "height": 800,
        "decorations": false,
        "resizable": false,
        "shadow": false,
        "skipTaskbar": true,
        "visibleOnAllWorkspaces": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "/Volumes/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
